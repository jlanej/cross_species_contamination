/*
 * Nextflow configuration for the CSC cross-species contamination pipeline.
 *
 * Supports execution via Docker, Singularity, local, and SLURM profiles.
 * Per-process resource settings are configurable through params.
 */

manifest {
    name            = 'cross_species_contamination'
    description     = 'Cross-species contamination detection pipeline (extract → classify → aggregate → detect)'
    version         = '0.2.0'
    mainScript      = 'main.nf'
    nextflowVersion = '>=22.10'
}

// Default process settings
process {
    container    = 'ghcr.io/jlanej/cross_species_contamination:latest'
    errorStrategy = 'finish'   // let other samples finish, then fail
    maxRetries    = 1
}

// Profiles for different execution environments
profiles {

    standard {
        process.executor = 'local'
    }

    docker {
        docker.enabled = true
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }

    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
        process.clusterOptions = ''
    }

    local {
        process.executor = 'local'
    }

    test {
        // Minimal resources for CI / local testing
        params.extract_cpus     = 1
        params.extract_memory   = '1 GB'
        params.extract_time     = '30m'

        params.classify_cpus    = 1
        params.classify_memory  = '2 GB'
        params.classify_time    = '30m'

        params.aggregate_cpus   = 1
        params.aggregate_memory = '1 GB'
        params.aggregate_time   = '30m'

        params.detect_cpus      = 1
        params.detect_memory    = '1 GB'
        params.detect_time      = '30m'
    }
}

// Timeline, report, and trace for debugging
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
    fields  = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,%mem,rss,vmem'
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.html"
}
