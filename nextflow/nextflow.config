/*
 * Nextflow configuration for the extract_unmapped pipeline.
 */

manifest {
    name            = 'cross_species_contamination/extract_unmapped'
    description     = 'Batch extraction of unmapped reads from BAM/CRAM files'
    version         = '0.1.0'
    mainScript      = 'extract_unmapped.nf'
    nextflowVersion = '>=22.10'
}

// Default process settings
process {
    container = 'ghcr.io/jlanej/cross_species_contamination:latest'
    cpus      = 4
    memory    = '4 GB'
}

// Profiles for different execution environments
profiles {
    standard {
        process.executor = 'local'
    }

    docker {
        docker.enabled = true
    }

    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
    }

    test {
        params.threads = 1
    }
}
